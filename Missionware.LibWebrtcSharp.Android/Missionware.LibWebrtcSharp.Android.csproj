<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0-android</TargetFramework>
    <SupportedOSPlatformVersion>21</SupportedOSPlatformVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- Enable trim analyzers for Android class libraries. -->
    <IsTrimmable>true</IsTrimmable>
	  <!-- Version: 3-segment scheme: 1 . (m125 + Stream 1.3.10) . 0 -->
	  <Version>1.12510310.1</Version>
	  <AssemblyVersion>1.0.0.0</AssemblyVersion>
	  <FileVersion>1.125.10310.1</FileVersion>
	  <Description>Android WebRTC (GetStream webrtc-android) packaged for .NET. Includes Java glue via AAR; H.264 via MediaCodec (hardware).</Description>
	  <Authors>Missionware</Authors>
	  <RepositoryUrl>https://github.com/missionware/libwebrtcsharp</RepositoryUrl>
	  <PackageLicenseExpression>BSD-3-Clause AND Apache-2.0</PackageLicenseExpression>
	  <PackageReadmeFile>README.md</PackageReadmeFile>
	  <PackageIcon>missionware-logo-small.png</PackageIcon>
	  <IsPackable>true</IsPackable>
	  <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
	  <IncludeSymbols>false</IncludeSymbols>
	  <NoWarn>NU5128</NoWarn>
  </PropertyGroup>
	<ItemGroup>
		<None Include="missionware-logo-small.png">
			<Pack>True</Pack>
			<PackagePath>\</PackagePath>
		</None>
		<None Include="README.md" Pack="true" PackagePath="" />
		<None Include="licenses\**\*" Pack="true" PackagePath="licenses\" />
	</ItemGroup>

</Project>